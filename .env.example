# 01. ✅ App ✅
APP_NAME="Career Agent"
APP_ENV=development
DEBUG=true
SECRET_KEY=your_secret_key_here
UI_USERNAME=your_username_here
UI_PASSWORD=your_password_here

# 02. Database
DATABASE_URL=your_database_url_here

# 03. Redis
REDIS_URL=your_redis_url_here

# 04. ✅ Telegram Bot ✅
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 05. ✅ Groq (free LLM API) ✅
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=your_groq_model_here

# 06. ✅ Ollama (local LLM) ✅
OLLAMA_BASE_URL=your_ollama_base_url_here
OLLAMA_MODEL=your_ollama_model_here
# "auto" = try Groq first, silently fall back to Ollama if Groq fails
LLM_PROVIDER=auto

# 07. ✅ Job Scraping ✅
JOB_SCRAPE_INTERVAL_HOURS=your_interval_here
JOB_MATCH_THRESHOLD=your_threshold_here
JOB_SITES=linkedin,indeed,glassdoor,zip_recruiter

# 08. ✅ Skill Update ✅
SKILL_UPDATE_INTERVAL_DAYS=your_recommended_interval_here

# 09. ✅ CV Generation ✅
CV_OUTPUT_DIR=resume/output
CV_TEMPLATE_DIR=resume/templates